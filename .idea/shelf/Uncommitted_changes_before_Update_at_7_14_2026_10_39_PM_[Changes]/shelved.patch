w items-center justify-between space-y-0\">\r\n          <CardTitle className=\"text-base\">Tất cả báo cáo</CardTitle>\r\n          <span className=\"text-sm text-muted-foreground\">\r\n            {history.length} mục\r\n          </span>\r\n        </CardHeader>\r\n        <CardContent className=\"p-0\">\r\n          <Table>\r\n            <TableHeader>\r\n              <TableRow>\r\n                <TableHead>File</TableHead>\r\n                <TableHead>Người tải lên</TableHead>\r\n                <TableHead>Lý do báo cáo</TableHead>\r\n                <TableHead>Người báo cáo</TableHead>\r\n                <TableHead>Ngày báo cáo</TableHead>\r\n                <TableHead>Trạng thái</TableHead>\r\n              </TableRow>\r\n            </TableHeader>\r\n            <TableBody>\r\n              {isLoading ? (\r\n                <TableRow>\r\n                  <TableCell\r\n                    colSpan={6}\r\n                    className=\"h-24 text-center text-muted-foreground\"\r\n                  >\r\n                    Đang tải dữ liệu...\r\n                  </TableCell>\r\n                </TableRow>\r\n              ) : history.length === 0 ? (\r\n                <TableRow>\r\n                  <TableCell\r\n                    colSpan={6}\r\n                    className=\"h-24 text-center text-muted-foreground\"\r\n                  >\r\n                    Không có báo cáo nào\r\n                  </TableCell>\r\n                </TableRow>\r\n              ) : (\r\n                history.map((item: any) => (\r\n                  <TableRow key={item.id}>\r\n                    <TableCell>\r\n                      <div className=\"flex items-center gap-3 min-w-0\">\r\n                        <div className=\"h-9 w-9 rounded-lg bg-destructive/10 text-destructive flex items-center justify-center shrink-0\">\r\n                          <Flag className=\"h-4 w-4\" />\r\n                        </div>\r\n                        <div className=\"min-w-0\">\r\n                          <span className=\"font-medium truncate block\">\r\n                            {item.title || item.name || \"Unknown\"}\r\n                          </span>\r\n                          <span className=\"text-xs text-muted-foreground truncate block\">\r\n                            ID: {item.documentId?.slice(0, 8) || \"N/A\"}\r\n                          </span>\r\n                        </div>\r\n                      </div>\r\n                    </TableCell>\r\n                    <TableCell>\r\n                      <div className=\"flex items-center gap-2.5\">\r\n                        <Avatar className=\"h-7 w-7\">\r\n                          <AvatarFallback className=\"bg-muted text-xs\">\r\n                            {item.uploader?.charAt(0) || \"U\"}\r\n                          </AvatarFallback>\r\n                        </Avatar>\r\n                        <span className=\"text-muted-foreground truncate\">\r\n                          {item.uploader}\r\n                        </span>\r\n                      </div>\r\n                    </TableCell>\r\n                    <TableCell>\r\n                      <div className=\"max-w-xs\">\r\n                        <div className=\"flex items-start gap-2\">\r\n                          <AlertCircle className=\"h-4 w-4 text-amber-500 shrink-0 mt-0.5\" />\r\n                          <span className=\"text-sm line-clamp-2\">\r\n                            {item.reason || \"Không có lý do\"}\r\n                          </span>\r\n                        </div>\r\n                      </div>\r\n                    </TableCell>\r\n                    <TableCell className=\"text-muted-foreground\">\r\n                      {item.reporter || \"Anonymous\"}\r\n                    </TableCell>\r\n                    <TableCell>\r\n                      <span className=\"text-sm\">\r\n                        {new Date(item.createdAt).toLocaleDateString(\"vi-VN\")}\r\n      