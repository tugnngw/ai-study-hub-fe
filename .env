VITE_API_BASE=http://localhost:4040

# Mock mode: when "true" (default if unset), the frontend uses canned
# in-memory data instead of calling the real backend above — useful for
# testing login / AIChat / Flashcards UI without a running server.
# Set to "false" to use the real backend at VITE_API_BASE.
VITE_MOCK_MODE=true
